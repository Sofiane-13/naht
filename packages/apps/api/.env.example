# =========================================================================
#  Base de données — Supabase (PostgreSQL managé), projet kbyqmmipnragqatugmit
#  Région eu-west-1 — plan Free : passer par le POOLER (IPv4), pas la
#  connexion directe db.<ref>.supabase.co (IPv6 uniquement).
#  Chaînes exactes : Dashboard > bouton "Connect" > onglet ORM > Prisma.
# =========================================================================
# Remplacez [YOUR-PASSWORD] par le mot de passe DB
# (Settings > Database > Reset database password).
#
# DATABASE_URL : runtime (adapter @prisma/adapter-pg) — transaction pooler 6543.
# DIRECT_URL   : Prisma Migrate — session pooler 5432.
DATABASE_URL="postgresql://postgres.kbyqmmipnragqatugmit:[YOUR-PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.kbyqmmipnragqatugmit:[YOUR-PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres"

# --- Auth ---
# Secret JWT : au moins 32 caractères. Générez-en un fort en prod :
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="dev-secret-change-me-please-32-chars-minimum-000"

# --- Environnement ---
NODE_ENV="development"
PORT="4000"

# URL du frontend autorisée par CORS
FRONTEND_URL="http://localhost:5173"

# --- Redis (optionnel) ---
# Si non défini, l'API stocke les codes OTP en mémoire (dev only).
# REDIS_URL="redis://localhost:6379"
