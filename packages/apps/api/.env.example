# =========================================================================
#  Base de données — Supabase (PostgreSQL managé)
#  Projet : kbyqmmipnragqatugmit
# =========================================================================
# Remplacez [YOUR-PASSWORD] par le mot de passe de la base
# (Supabase Dashboard > Project Settings > Database > Database password).
#
# DATABASE_URL  : utilisée au runtime par l'app (adapter @prisma/adapter-pg).
# DIRECT_URL    : utilisée par Prisma Migrate (connexion directe, port 5432).
#
# Option perf : pour le runtime, vous pouvez pointer DATABASE_URL vers le
# pooler Supabase (port 6543, ?pgbouncer=true) et garder DIRECT_URL en 5432.
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.kbyqmmipnragqatugmit.supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.kbyqmmipnragqatugmit.supabase.co:5432/postgres"

# --- Auth ---
# Secret JWT : au moins 32 caractères. Générez-en un fort en prod :
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="dev-secret-change-me-please-32-chars-minimum-000"

# --- Environnement ---
NODE_ENV="development"
PORT="4000"

# URL du frontend autorisée par CORS
FRONTEND_URL="http://localhost:5173"

# --- Redis (optionnel) ---
# Si non défini, l'API stocke les codes OTP en mémoire (dev only).
# REDIS_URL="redis://localhost:6379"
