{
  "name": "naht",
  "private": true,
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@9.15.1",
  "scripts": {
    "dev": "nx run-many --target=dev",
    "dev:api": "cd packages/apps/api && pnpm dev",
    "dev:frontend": "cd packages/apps/frontend/app && pnpm dev",
    "build": "nx run-many --target=build",
    "lint": "nx run-many --target=lint",
    "format": "nx run-many --target=format",
    "db:setup": "cd packages/apps/api && pnpm db:setup",
    "db:migrate": "cd packages/apps/api && pnpm prisma:migrate"
  },
  "devDependencies": {
    "nx": "^20.3.0",
    "prettier": "^3.4.2",
    "npm-run-all": "^4.1.5",
    "cross-env": "^7.0.3"
  }
}
